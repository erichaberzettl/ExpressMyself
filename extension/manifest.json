{
  "manifest_version": 3,
  "name": "ExpressMyself",
  "description": "Learn practical idioms and expressions from a lightweight popup and library page.",
  "version": "0.1.0",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "ExpressMyself",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    }
  },
  "options_page": "app.html",
  "permissions": ["storage"]
}
